# ===========================
# AutoHDR v2 Backend Settings
# ===========================

# --- API Configuration ---
AUTOHDR_BASE_URL=https://www.autohdr.com
AUTOHDR_USER_AGENT="Mozilla/5.0 (X11; Ubuntu; Linux x86_64; rv:148.0) Gecko/20100101 Firefox/148.0"
# --- Authentication ---
# Paste your full cookie string here (from browser DevTools)
AUTOHDR_COOKIE=your_cookie_here

AUTOHDR_PROXY_USER=your_username
AUTOHDR_PROXY_PASS=your_password


# --- Default Address ---
AUTOHDR_ADDRESS=default_address

# --- Proxy Configuration (optional) ---
# AUTOHDR_PROXY_HTTP=http://proxy:8080
# AUTOHDR_PROXY_HTTPS=https://proxy:8080

# --- Output Configuration ---
AUTOHDR_RESOURCES_DIR=./resources

# --- Download Limits ---
AUTOHDR_LIMIT_COUNT=1000
AUTOHDR_LIMIT_FILE=50

# --- Retry Configuration ---
AUTOHDR_RETRY_MAX_ATTEMPTS=10
AUTOHDR_RETRY_INITIAL_DELAY=15.0
AUTOHDR_RETRY_BACKOFF_FACTOR=1.5

# --- Photoshoot Settings ---
AUTOHDR_PHOTOSHOOT_LIMIT=20
AUTOHDR_PHOTOSHOOT_PAGE_SIZE=10
